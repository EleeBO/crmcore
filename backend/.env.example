# STT Provider — "salutespeech" (default) or "deepgram"
STT_PROVIDER=salutespeech

# Deepgram (alternative STT provider)
DEEPGRAM_API_KEY=

# SaluteSpeech (primary STT via gRPC, requires Russian Trusted Root CA cert)
# API key: Base64-encoded client_id:client_secret from developers.sber.ru
SBER_SPEECH_API_KEY=
# OAuth scope: SALUTE_SPEECH_PERS (personal) or SALUTE_SPEECH_CORP (corporate)
SBER_SPEECH_SCOPE=SALUTE_SPEECH_PERS

# OpenRouter (LLM) — required for scenario generation
OPENROUTER_API_KEY=sk-or-v1-...

# Infrastructure
REDIS_URL=redis://localhost:6379

# LLM Models
LLM_PRIMARY_MODEL=google/gemini-2.5-flash
LLM_FALLBACK_MODEL=openai/gpt-4.1-mini
LLM_PRIMARY_TIMEOUT_MS=1000
LLM_FALLBACK_TIMEOUT_MS=2000

# VAD
VAD_THRESHOLD=0.5

# Logging
LOG_LEVEL=INFO
